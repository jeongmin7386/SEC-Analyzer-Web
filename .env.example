# SEC EDGAR request identity. Use a descriptive app name and contact email.
SEC_USER_AGENT=
SEC_CONTACT_EMAIL=

# OpenDART API key for Korean stock financial statements.
OPENDART_API_KEY=

# Optional price data provider key for future providers. The current build uses yfinance.
STOCK_PRICE_API_KEY=

# Optional comma-separated frontend origins for local development.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
