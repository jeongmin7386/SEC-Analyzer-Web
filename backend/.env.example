# SEC EDGAR request identity.
SEC_USER_AGENT=
SEC_CONTACT_EMAIL=

# OpenDART API key for Korean stock analysis.
OPENDART_API_KEY=

# Optional future price provider key. Current price provider uses yfinance.
STOCK_PRICE_API_KEY=

# Local frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5174

# Optional exchange-rate provider override.
EXCHANGE_RATE_BASE_URL=https://api.frankfurter.app
